{
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "http://34.93.151.212:3002/api/:path*"
    }
  ],
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "Access-Control-Allow-Origin", "value": "*" },
        { "key": "Access-Control-Allow-Methods", "value": "GET,POST,PATCH,DELETE,OPTIONS" },
        { "key": "Access-Control-Allow-Headers", "value": "Content-Type,X-Kiosk-ID" }
      ]
    }
  ]
}
